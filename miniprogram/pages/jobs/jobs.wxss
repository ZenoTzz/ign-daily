.job-list{margin-top:28rpx}.job-item{margin-bottom:18rpx}.job-top,.job-foot{display:flex;justify-content:space-between;align-items:center}.job-date{font-size:30rpx;font-weight:800}.job-status{padding:6rpx 12rpx;border-radius:8rpx;color:#aeb0b8;background:#29292d;font-size:21rpx}.status-running{color:#8eb1ff;background:rgba(53,103,255,.15)}.status-done{color:#65d3a5;background:rgba(33,183,122,.14)}.status-failed{color:#ff9298;background:rgba(237,28,36,.14)}.job-ids{margin-top:14rpx;color:#f4f4f5;font-size:25rpx}.job-message{margin-top:8rpx;color:#8f9199;font-size:23rpx}.job-progress{height:10rpx;margin-top:20rpx;overflow:hidden;border-radius:99rpx;background:#29292d}.job-progress view{height:100%;border-radius:99rpx;background:#ed1c24}.job-foot{margin-top:10rpx;color:#8f9199;font-size:21rpx}
