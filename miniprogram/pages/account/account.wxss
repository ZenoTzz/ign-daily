.account-hero{display:flex;align-items:center;gap:22rpx;margin-bottom:30rpx}.avatar{display:flex;width:88rpx;height:88rpx;align-items:center;justify-content:center;border-radius:18rpx;background:#ed1c24;color:#fff;font-size:24rpx;font-weight:900}.account-status,.account-status view,.menu-row{display:flex;align-items:center;justify-content:space-between}.account-status{font-size:24rpx}.status-dot{display:inline-block;width:14rpx;height:14rpx;margin-right:12rpx;border-radius:50%;background:#21b77a;box-shadow:0 0 0 7rpx rgba(33,183,122,.12)}.menu-panel{padding:0 26rpx}.menu-row{min-height:92rpx;font-size:27rpx}.edit-form{display:grid;gap:16rpx;padding:8rpx 0 26rpx;border-top:1rpx solid #303136}.edit-form .input:first-child{margin-top:18rpx}.logout-btn{height:82rpx;margin:34rpx 0 0;border:1rpx solid rgba(237,28,36,.36);border-radius:14rpx;background:rgba(237,28,36,.08);color:#ff747b;font-size:27rpx;font-weight:800}.version{padding:40rpx 0;color:#606169;text-align:center;font-size:20rpx}
