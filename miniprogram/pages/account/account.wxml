<view class="page">
  <view class="account-hero">
    <view class="avatar">IGN</view><view><view class="page-title">{{username || '账号'}}</view><view class="page-subtitle">已连接 igndaily.site</view></view>
  </view>
  <view class="panel account-status"><view><text class="status-dot"></text><text>服务器登录正常</text></view><text class="muted">{{wechatBound ? '微信管理员已绑定' : '账号登录'}}</text></view>
  <view class="section-label">使用说明</view>
  <view class="panel menu-panel"><view class="menu-row"><text>翻译完成提醒</text><text class="muted">提交任务时按需授权</text></view><view class="menu-row"><text>账号与密码管理</text><text class="muted">请在主站设置中操作</text></view></view>
  <button class="logout-btn" bindtap="logout">退出登录</button>
  <view class="version">IGN Daily 小程序 · API https://igndaily.site</view>
</view>
