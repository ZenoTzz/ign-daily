<view class="page">
  <view wx:if="{{loading}}" class="panel muted">加载中...</view>
  <view wx:elif="{{error}}" class="panel error">{{error}}</view>
  <view wx:else>
    <view class="article-head">
      <view class="tag">#{{article.id}}</view>
      <view class="title">{{article.cn_title || article.title_cn || article.en_title}}</view>
      <view class="subtitle">{{article.en_title || article.title_en}}</view>
      <view class="tag">{{reviewLabel}}</view>
      <view wx:if="{{reviewReason}}" class="subtitle">复核信息：{{reviewReason}}</view>
    </view>

    <button wx:if="{{images.length}}" class="btn btn-ghost" bindtap="toggleImages"><text wx:if="{{showImages}}">收起配图</text><text wx:else>查看配图（{{images.length}}）</text></button>
    <scroll-view wx:if="{{images.length && showImages}}" class="image-strip" scroll-x enhanced show-scrollbar="{{false}}">
      <image wx:for="{{images}}" wx:key="*this" src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="previewImage"></image>
    </scroll-view>

    <view class="panel section summary-panel">
      <view class="section-title">摘要</view>
      <view class="body-text">{{article.opus_summary || article.summary || article.cn_summary || article.description || '暂无摘要'}}</view>
    </view>

    <view class="panel section" wx:if="{{bodyText}}">
      <view class="section-title">正文</view>
      <view class="body-text">{{bodyText}}</view>
    </view>

    <view class="article-actions"><button class="btn btn-primary" bindtap="copyArticle">复制译文</button><button class="btn btn-ghost" bindtap="copyUrl">复制原文链接</button></view>
    <view class="article-actions"><button class="btn btn-ghost" disabled="{{!prevId}}" data-id="{{prevId}}" bindtap="goSibling">上一篇</button><button class="btn btn-ghost" disabled="{{!nextId}}" data-id="{{nextId}}" bindtap="goSibling">下一篇</button></view>
  </view>
</view>
