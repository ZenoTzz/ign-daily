.article-head {
  margin-bottom: 24rpx;
}

.title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.subtitle {
  margin-top: 16rpx;
  color: #9295a8;
  font-size: 26rpx;
  line-height: 1.4;
}

.section {
  margin-bottom: 22rpx;
}
.summary-panel{border-left:6rpx solid #f2b91d;background:#201d18}.image-strip{width:100%;margin-bottom:24rpx;white-space:nowrap}.image-strip image{display:inline-block;width:360rpx;height:220rpx;margin-right:14rpx;border-radius:16rpx;background:#202024}.article-actions{display:flex;gap:14rpx;padding-bottom:24rpx}.article-actions button{flex:1;margin:0;font-size:25rpx}
.summary-hint{margin:-6rpx 0 14rpx;color:#a9a18f;font-size:21rpx;line-height:1.5}.translation-wait{margin-bottom:22rpx;padding:28rpx;border:1rpx dashed #34343a;border-radius:18rpx;color:#8f9199;background:#151517;text-align:center;font-size:24rpx;line-height:1.6}.article-actions button[disabled]{color:#777981;background:#202023;opacity:1}

.section-title {
  margin-bottom: 16rpx;
  color: #ef2330;
  font-size: 26rpx;
  font-weight: 900;
}

.body-text {
  color: #e8eaf4;
  font-size: 29rpx;
  line-height: 1.72;
  white-space: pre-wrap;
}

.error {
  color: #ffadb3;
}
