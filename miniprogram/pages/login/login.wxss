.login-page {
  padding-top: 120rpx;
}

.brand {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef2330;
  font-weight: 900;
}

.title {
  margin-left: 24rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 8rpx;
  margin-left: 24rpx;
  color: #9295a8;
  font-size: 26rpx;
}

.login-panel {
  display: flex;
  flex-direction: column;
}

.login-panel .input,
.login-panel .login-btn,
.login-panel .hint {
  margin-top: 22rpx;
}

.login-panel .input:first-child {
  margin-top: 0;
}

.placeholder {
  color: #686c7f;
}

.login-btn {
  margin-top: 8rpx;
}

.hint {
  font-size: 24rpx;
  line-height: 1.6;
}
