<view class="page login-page">
  <view class="brand">
    <view class="mark">IGN</view>
    <view>
      <view class="title">IGN Daily</view>
      <view class="subtitle">服务器账号登录</view>
    </view>
  </view>

  <view class="panel login-panel">
    <input class="input" value="{{username}}" placeholder="用户名" placeholder-class="placeholder"
      bindinput="onUsernameInput" />
    <input class="input" value="{{password}}" password placeholder="密码" placeholder-class="placeholder"
      bindinput="onPasswordInput" confirm-type="done" bindconfirm="submit" />
    <button class="btn btn-primary login-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">
      登录
    </button>
    <view class="hint muted">和网页端使用同一个服务器账号。不要填写服务器 SSH 密码。</view>
  </view>
</view>
