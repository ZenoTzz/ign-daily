.dict-head{display:flex;justify-content:space-between;align-items:flex-start}.add-btn{margin:0;width:116rpx;height:64rpx;line-height:64rpx;border-radius:12rpx;background:#ed1c24;color:#fff;font-size:24rpx;font-weight:800}.add-form{display:grid;gap:16rpx;margin-top:24rpx}.add-form .btn{margin-top:4rpx}.picker-value{line-height:88rpx}.search-box{display:flex;align-items:center;gap:14rpx;height:82rpx;margin:26rpx 0 20rpx;padding:0 22rpx;border:1rpx solid #303136;border-radius:16rpx;background:#171719;color:#8f9199}.search-box input{flex:1;color:#f4f4f5;font-size:26rpx}.dict-list{border-top:1rpx solid #303136}.dict-row{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx;padding:22rpx 4rpx;border-bottom:1rpx solid #26262a}.dict-copy{display:flex;flex:1;min-width:0;flex-direction:column}.dict-en{color:#fff;font-size:27rpx;font-weight:800;word-break:break-all}.dict-cn{margin-top:5rpx;color:#d4d4d8;font-size:25rpx}.dict-note{margin-top:5rpx;color:#777982;font-size:21rpx}.dict-cat{padding:5rpx 9rpx;border-radius:7rpx;background:#242428;color:#92949d;font-size:19rpx}.list-note{padding:28rpx;color:#777982;text-align:center;font-size:22rpx}
