.topbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.kicker {
  color: #ef2330;
  font-size: 24rpx;
  font-weight: 800;
}

.headline {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.logout {
  margin: 0;
  width: 116rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #c6c9d8;
  background: rgba(255, 255, 255, 0.08);
}

.date-row {
  display: flex;
  margin: 32rpx 0 24rpx;
}

.date-btn {
  flex: 1;
  margin-left: 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #f6f7fb;
  background: rgba(255, 255, 255, 0.08);
}

.date-btn:first-child {
  margin-left: 0;
}

.job-panel {
  margin-bottom: 24rpx;
}

.job-head {
  display: flex;
  justify-content: space-between;
  font-weight: 800;
}

.progress {
  height: 10rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
}

.progress-inner {
  height: 100%;
  background: #ef2330;
}

.job-meta {
  margin-top: 14rpx;
  font-size: 22rpx;
}

.summary {
  display: flex;
  margin-bottom: 24rpx;
}

.summary-card {
  flex: 1;
  margin-left: 16rpx;
  min-height: 116rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.055);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #aeb2c4;
  font-size: 22rpx;
}

.summary-card:first-child {
  margin-left: 0;
}

.num {
  display: block;
  margin-bottom: 6rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.actions {
  display: flex;
  margin-bottom: 24rpx;
}

.actions .btn-primary {
  flex: 1;
  margin-right: 16rpx;
}

.actions .btn-ghost {
  width: 160rpx;
}

.error {
  margin-bottom: 24rpx;
  color: #ffadb3;
  font-size: 26rpx;
}

.article-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.055);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.article-main {
  display: flex;
}

.article-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.article-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.article-subtitle {
  margin-top: 10rpx;
  color: #9295a8;
  font-size: 24rpx;
  line-height: 1.35;
}

.article-meta {
  display: flex;
  margin-top: 16rpx;
}

.article-meta .tag {
  margin-right: 12rpx;
}
