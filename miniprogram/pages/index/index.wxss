.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 8rpx;
  margin-bottom: 28rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.kicker {
  color: #ef2330;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 800;
}

.headline {
  margin-top: 8rpx;
  color: #fff;
  font-size: 48rpx;
  line-height: 58rpx;
  font-weight: 900;
}

.subline {
  margin-top: 10rpx;
  color: #8d91a5;
  font-size: 24rpx;
  line-height: 34rpx;
}

.logout {
  margin: 8rpx 0 0;
  width: 112rpx;
  height: 56rpx;
  line-height: 56rpx;
  flex: 0 0 112rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #dfe2f0;
  background: rgba(255, 255, 255, 0.08);
}

.date-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.date-picker { flex: 1; min-width: 0; }

.date-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 14rpx;
  color: #dfe2f0;
  background: rgba(255, 255, 255, 0.075);
  font-size: 24rpx;
  font-weight: 700;
}

.today-btn {
  background: rgba(239, 35, 48, 0.18);
  color: #fff;
}

.job-card {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(239, 35, 48, 0.1);
  border: 1rpx solid rgba(239, 35, 48, 0.22);
}

.job-head {
  display: flex;
  justify-content: space-between;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
}

.progress {
  height: 10rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.14);
}

.progress-inner {
  height: 100%;
  background: #ef2330;
}

.job-meta {
  margin-top: 12rpx;
  color: #aeb2c4;
  font-size: 22rpx;
  line-height: 30rpx;
}

.summary {
  display: flex;
  margin-bottom: 22rpx;
}

.summary-card {
  flex: 1;
  margin-left: 12rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #aeb2c4;
  font-size: 22rpx;
}

.summary-card:first-child {
  margin-left: 0;
}

.num {
  margin-bottom: 4rpx;
  color: #fff;
  font-size: 34rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.actions {
  display: flex;
  margin-bottom: 22rpx;
}

.window-line {
  margin-top: 8rpx;
  color: #f3b7bc;
  font-size: 22rpx;
  line-height: 32rpx;
}
.filter-scroll { width: 100%; margin-bottom: 20rpx; white-space: nowrap; }
.filter-row { display: inline-flex; gap: 12rpx; padding-right: 24rpx; }
.filter-btn { height: 60rpx; padding: 0 24rpx; border-radius: 12rpx; background: #1d1d20; color: #9799a1; font-size: 23rpx; line-height: 60rpx; }
.filter-btn.active { background: rgba(237,28,36,.14); color: #ff5d64; box-shadow: inset 0 0 0 1rpx rgba(237,28,36,.28); }
.queue-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; color: #fff; font-size: 28rpx; font-weight: 800; }
.select-all { height: 52rpx; padding: 0 18rpx; border-radius: 10rpx; background: #222226; color: #a9abb3; font-size: 21rpx; font-weight: 700; line-height: 52rpx; }
.selected-card { border-color: rgba(237,28,36,.55); background: rgba(237,28,36,.055); }
.confirm-mask{position:fixed;z-index:100;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.72)}
.confirm-sheet{box-sizing:border-box;width:100%;padding:16rpx 30rpx calc(32rpx + env(safe-area-inset-bottom));border:1rpx solid #303036;border-bottom:0;border-radius:28rpx 28rpx 0 0;background:#171719;box-shadow:0 -18rpx 60rpx rgba(0,0,0,.42)}
.confirm-handle{width:72rpx;height:7rpx;margin:0 auto 24rpx;border-radius:999rpx;background:#4a4a50}
.confirm-title{color:#fff;font-size:34rpx;line-height:44rpx;font-weight:900;text-align:center}
.confirm-subtitle{margin-top:8rpx;color:#8f9199;font-size:22rpx;line-height:32rpx;text-align:center}
.confirm-list{max-height:360rpx;margin:24rpx 0;border-top:1rpx solid #2c2c31;border-bottom:1rpx solid #2c2c31}
.confirm-item{display:flex;align-items:flex-start;gap:16rpx;padding:20rpx 4rpx;border-bottom:1rpx solid #29292d}
.confirm-item:last-child{border-bottom:0}
.confirm-id{flex:0 0 auto;padding:4rpx 10rpx;border-radius:999rpx;background:#2a2a2e;color:#b7b8c0;font-size:20rpx;line-height:28rpx}
.confirm-item-title{flex:1;min-width:0;color:#f4f4f5;font-size:25rpx;line-height:36rpx;font-weight:700}
.confirm-actions{display:flex;gap:14rpx}
.confirm-btn{display:flex;align-items:center;justify-content:center;flex:1;height:78rpx;border-radius:14rpx;background:#28282c;color:#f3f3f5;font-size:26rpx;font-weight:800}
.confirm-btn.primary{background:#ed1c24;color:#fff}

.submit-btn {
  flex: 1;
  margin: 0 14rpx 0 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  color: #fff;
  background: #ef2330;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
}

.refresh-btn {
  width: 136rpx;
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.09);
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

.control-disabled { opacity: .42; }
.submit-btn.control-disabled, .refresh-btn.control-disabled { color: #9b9ca3; background: #202023; }

.error {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  color: #ffadb3;
  background: rgba(239, 35, 48, 0.08);
  font-size: 24rpx;
}

.list {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.article-card {
  display: flex;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
}

.thumb-wrap {
  position: relative;
  width: 148rpx;
  height: 112rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
}

.thumb {
  width: 148rpx;
  height: 112rpx;
  display: block;
}

.thumb-empty {
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 112rpx;
  text-align: center;
  background: #202231;
}

.id-badge {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  min-width: 44rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.56);
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.article-copy {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.article-row {
  display: flex;
}

.article-title {
  color: #fff;
  font-size: 27rpx;
  line-height: 35rpx;
  font-weight: 850;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-subtitle {
  margin-top: 8rpx;
  color: #9ba0bb;
  font-size: 22rpx;
  line-height: 30rpx;
  max-height: 30rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.article-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.status {
  height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #bfc3d8;
  background: rgba(255, 255, 255, 0.08);
  font-size: 21rpx;
  line-height: 38rpx;
}

.status-done {
  color: #b7f7d1;
  background: rgba(34, 197, 94, 0.14);
}

.status-requested {
  color: #b9d4ff;
  background: rgba(59, 130, 246, 0.16);
}

.status-review {
  color: #ffe0a3;
  background: rgba(245, 158, 11, 0.16);
}

.select-btn {
  min-width: 104rpx;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.1);
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.select-btn.selected {
  background: #ef2330;
}

.select-btn.control-disabled {
  color: #8f94a8;
  background: rgba(255, 255, 255, 0.06);
}
