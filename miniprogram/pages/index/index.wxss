.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 8rpx;
  margin-bottom: 28rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.kicker {
  color: #ef2330;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 800;
}

.headline {
  margin-top: 8rpx;
  color: #fff;
  font-size: 48rpx;
  line-height: 58rpx;
  font-weight: 900;
}

.subline {
  margin-top: 10rpx;
  color: #8d91a5;
  font-size: 24rpx;
  line-height: 34rpx;
}

.logout {
  margin: 8rpx 0 0;
  width: 112rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #dfe2f0;
  background: rgba(255, 255, 255, 0.08);
}

.date-row {
  display: flex;
  margin-bottom: 22rpx;
}

.date-btn {
  flex: 1;
  margin-left: 12rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 14rpx;
  color: #dfe2f0;
  background: rgba(255, 255, 255, 0.075);
  font-size: 24rpx;
  font-weight: 700;
}

.date-btn:first-child {
  margin-left: 0;
}

.today-btn {
  background: rgba(239, 35, 48, 0.18);
  color: #fff;
}

.job-card {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(239, 35, 48, 0.1);
  border: 1rpx solid rgba(239, 35, 48, 0.22);
}

.job-head {
  display: flex;
  justify-content: space-between;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
}

.progress {
  height: 10rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.14);
}

.progress-inner {
  height: 100%;
  background: #ef2330;
}

.job-meta {
  margin-top: 12rpx;
  color: #aeb2c4;
  font-size: 22rpx;
  line-height: 30rpx;
}

.summary {
  display: flex;
  margin-bottom: 22rpx;
}

.summary-card {
  flex: 1;
  margin-left: 12rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #aeb2c4;
  font-size: 22rpx;
}

.summary-card:first-child {
  margin-left: 0;
}

.num {
  margin-bottom: 4rpx;
  color: #fff;
  font-size: 34rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.actions {
  display: flex;
  margin-bottom: 22rpx;
}

.window-line {
  margin-top: 8rpx;
  color: #f3b7bc;
  font-size: 22rpx;
  line-height: 32rpx;
}
.filter-scroll{width:100%;margin-bottom:20rpx;white-space:nowrap}.filter-row{display:inline-flex;gap:12rpx}.filter-btn{display:inline-block;width:auto;height:60rpx;margin:0;padding:0 24rpx;border-radius:12rpx;background:#1d1d20;color:#9799a1;font-size:23rpx;line-height:60rpx}.filter-btn.active{background:rgba(237,28,36,.14);color:#ff5d64;border:1rpx solid rgba(237,28,36,.28)}.queue-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx;color:#fff;font-size:28rpx;font-weight:800}.queue-head button{margin:0;height:52rpx;padding:0 16rpx;border-radius:10rpx;background:#222226;color:#a9abb3;font-size:21rpx;line-height:52rpx}.selected-card{border-color:rgba(237,28,36,.55);background:rgba(237,28,36,.055)}

.submit-btn {
  flex: 1;
  margin: 0 14rpx 0 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  color: #fff;
  background: #ef2330;
  font-size: 28rpx;
  font-weight: 800;
}

.submit-btn[disabled] {
  color: rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.09);
}

.refresh-btn {
  width: 136rpx;
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.09);
  font-size: 26rpx;
  font-weight: 800;
}

.error {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  color: #ffadb3;
  background: rgba(239, 35, 48, 0.08);
  font-size: 24rpx;
}

.list {
  padding-bottom: 56rpx;
}

.article-card {
  display: flex;
  margin-bottom: 18rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
}

.thumb-wrap {
  position: relative;
  width: 176rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
}

.thumb {
  width: 176rpx;
  height: 132rpx;
  display: block;
}

.thumb-empty {
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 132rpx;
  text-align: center;
  background: #202231;
}

.id-badge {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  min-width: 44rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.56);
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.article-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.article-row {
  display: flex;
}

.article-title {
  color: #fff;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 850;
}

.article-subtitle {
  margin-top: 8rpx;
  color: #9ba0bb;
  font-size: 22rpx;
  line-height: 30rpx;
  max-height: 60rpx;
  overflow: hidden;
}

.article-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.status {
  height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #bfc3d8;
  background: rgba(255, 255, 255, 0.08);
  font-size: 21rpx;
  line-height: 38rpx;
}

.status-done {
  color: #b7f7d1;
  background: rgba(34, 197, 94, 0.14);
}

.status-requested {
  color: #b9d4ff;
  background: rgba(59, 130, 246, 0.16);
}

.status-review {
  color: #ffe0a3;
  background: rgba(245, 158, 11, 0.16);
}

.select-btn {
  width: 92rpx;
  height: 44rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.1);
  font-size: 22rpx;
  line-height: 44rpx;
}

.select-btn.selected {
  background: #ef2330;
}

.select-btn.disabled {
  color: #8f94a8;
  background: rgba(255, 255, 255, 0.06);
}
