<view class="page">
  <view class="hero">
    <view class="hero-copy">
      <view class="kicker">{{date}} 新闻日</view>
      <view class="headline">翻译工作台</view>
      <view class="subline">{{articles.length}} 条文章 · {{requestedCount}} 篇进行中</view>
      <view class="window-line">下次自动翻译窗口：{{nextTranslationWindow}}</view>
    </view>
    <view class="logout" role="button" bindtap="openJobs">任务</view>
  </view>

  <view class="date-row">
    <view class="date-btn" role="button" bindtap="prevDate">前一天</view>
    <picker class="date-picker" mode="date" value="{{date}}" end="{{todayDate}}" bindchange="onDateChange"><view class="date-btn today-btn">{{date}}</view></picker>
    <view class="date-btn {{isToday ? 'control-disabled' : ''}}" role="button" bindtap="nextDate">后一天</view>
  </view>

  <view wx:if="{{job}}" class="job-card">
    <view class="job-head">
      <text>{{jobLabel}}</text>
      <text>{{job.progress || 0}}%</text>
    </view>
    <view class="progress"><view class="progress-inner" style="width: {{job.progress || 0}}%;"></view></view>
    <view class="job-meta">{{job.date}} · #{{jobIdsText}}</view>
  </view>

  <view class="summary">
    <view class="summary-card">
      <text class="num">{{pendingCount}}</text>
      <text>待选择</text>
    </view>
    <view class="summary-card">
      <text class="num">{{requestedCount}}</text>
      <text>翻译中</text>
    </view>
    <view class="summary-card">
      <text class="num">{{doneCount}}</text>
      <text>已完成</text>
    </view>
  </view>

  <view class="actions">
    <view class="submit-btn {{selectedIds.length === 0 || submitting ? 'control-disabled' : ''}}" role="button" bindtap="submitSelected">{{submitting ? '提交中…' : submitText}}</view>
    <view class="refresh-btn {{loading ? 'control-disabled' : ''}}" role="button" bindtap="loadData">{{loading ? '刷新中…' : '刷新'}}</view>
  </view>

  <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-row">
      <view wx:for="{{filters}}" wx:key="key" class="filter-btn {{filter === item.key ? 'active' : ''}}" role="button" data-filter="{{item.key}}" bindtap="setFilter">{{item.label}}</view>
    </view>
  </scroll-view>
  <view class="queue-head"><text>文章队列 · {{visibleArticles.length}}</text><view class="select-all" role="button" bindtap="selectAllPending">全选可用</view></view>

  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="list">
    <view wx:if="{{!loading && !visibleArticles.length}}" class="empty-state">当前筛选下没有文章</view>
    <view wx:for="{{visibleArticles}}" wx:key="id" class="article-card {{item.selected ? 'selected-card' : ''}}" bindtap="openArticle" data-id="{{item.id}}">
      <view class="thumb-wrap">
        <image wx:if="{{item.cover_image}}" class="thumb" src="{{item.cover_image}}" mode="aspectFill"></image>
        <view wx:else class="thumb thumb-empty">IGN</view>
        <view class="id-badge">#{{item.id}}</view>
      </view>

      <view class="article-copy">
        <view class="article-row">
          <text class="article-title">{{item.cn_title || item.en_title}}</text>
        </view>
        <view class="article-subtitle">{{item.en_title}}</view>
        <view class="article-footer">
          <text class="status {{item.status_class}}">{{item.status_label}}</text>
          <view class="select-btn {{item.selected ? 'selected' : ''}} {{item.select_disabled ? 'control-disabled' : ''}}"
            role="button"
            data-id="{{item.id}}"
            catchtap="toggleSelect">
            {{item.select_label}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{confirmOpen}}" class="confirm-mask" catchtap="closeSubmitConfirm">
    <view class="confirm-sheet" catchtap="noop">
      <view class="confirm-handle"></view>
      <view class="confirm-title">确认提交 {{confirmArticles.length}} 篇？</view>
      <view class="confirm-subtitle">提交后会进入 Codex 翻译队列</view>
      <scroll-view class="confirm-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:for="{{confirmArticles}}" wx:key="id" class="confirm-item">
          <text class="confirm-id">#{{item.id}}</text>
          <text class="confirm-item-title">{{item.title}}</text>
        </view>
      </scroll-view>
      <view class="confirm-actions">
        <view class="confirm-btn cancel" role="button" bindtap="closeSubmitConfirm">取消</view>
        <view class="confirm-btn primary" role="button" bindtap="confirmSubmit">确认提交</view>
      </view>
    </view>
  </view>
</view>
