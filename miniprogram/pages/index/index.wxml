<view class="page">
  <view class="hero">
    <view class="hero-copy">
      <view class="kicker">{{date}} 新闻日</view>
      <view class="headline">翻译工作台</view>
      <view class="subline">{{articles.length}} 条文章 · {{requestedCount}} 篇进行中</view>
    </view>
    <button class="logout" bindtap="openJobs">任务</button>
  </view>

  <view class="date-row">
    <button class="date-btn" bindtap="prevDate">前一天</button>
    <button class="date-btn today-btn" bindtap="today">今天</button>
    <button class="date-btn" bindtap="nextDate">后一天</button>
  </view>

  <view wx:if="{{job}}" class="job-card">
    <view class="job-head">
      <text>{{jobLabel}}</text>
      <text>{{job.progress || 0}}%</text>
    </view>
    <view class="progress"><view class="progress-inner" style="width: {{job.progress || 0}}%;"></view></view>
    <view class="job-meta">{{job.date}} · #{{jobIdsText}}</view>
  </view>

  <view class="summary">
    <view class="summary-card">
      <text class="num">{{pendingCount}}</text>
      <text>待选择</text>
    </view>
    <view class="summary-card">
      <text class="num">{{requestedCount}}</text>
      <text>翻译中</text>
    </view>
    <view class="summary-card">
      <text class="num">{{doneCount}}</text>
      <text>已完成</text>
    </view>
  </view>

  <view class="actions">
    <button class="submit-btn" disabled="{{selectedIds.length === 0 || submitting}}" loading="{{submitting}}" bindtap="submitSelected">
      {{submitText}}
    </button>
    <button class="refresh-btn" disabled="{{loading}}" loading="{{loading}}" bindtap="loadData">刷新</button>
  </view>

  <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-row">
      <button wx:for="{{filters}}" wx:key="key" class="filter-btn {{filter === item.key ? 'active' : ''}}" data-filter="{{item.key}}" bindtap="setFilter">{{item.label}}</button>
    </view>
  </scroll-view>
  <view class="queue-head"><text>文章队列 · {{visibleArticles.length}}</text><button bindtap="selectAllPending">全选可用</button></view>

  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="list">
    <view wx:if="{{!loading && !visibleArticles.length}}" class="empty-state">当前筛选下没有文章</view>
    <view wx:for="{{visibleArticles}}" wx:key="id" class="article-card {{item.selected ? 'selected-card' : ''}}" bindtap="openArticle" data-id="{{item.id}}">
      <view class="thumb-wrap">
        <image wx:if="{{item.cover_image}}" class="thumb" src="{{item.cover_image}}" mode="aspectFill"></image>
        <view wx:else class="thumb thumb-empty">IGN</view>
        <view class="id-badge">#{{item.id}}</view>
      </view>

      <view class="article-copy">
        <view class="article-row">
          <text class="article-title">{{item.cn_title || item.en_title}}</text>
        </view>
        <view class="article-subtitle">{{item.en_title}}</view>
        <view class="article-footer">
          <text class="status {{item.status_class}}">{{item.status_label}}</text>
          <button class="select-btn {{item.selected ? 'selected' : ''}} {{item.translation_status === 'done' ? 'disabled' : ''}}"
            disabled="{{item.select_disabled}}"
            data-id="{{item.id}}"
            catchtap="toggleSelect">
            {{item.select_label}}
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
