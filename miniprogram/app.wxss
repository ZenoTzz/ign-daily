page {
  min-height: 100%;
  background: #0b0b14;
  color: #f6f7fb;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background: radial-gradient(circle at 20% 0%, rgba(239, 35, 45, 0.18), transparent 38%),
    linear-gradient(180deg, #10111d 0%, #0b0b14 100%);
}

.panel {
  background: rgba(255, 255, 255, 0.055);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 16rpx;
  padding: 28rpx;
}

.muted {
  color: #9295a8;
}

.btn {
  height: 84rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 84rpx;
}

.btn-primary {
  color: #fff;
  background: #ef2330;
}

.btn-ghost {
  color: #f6f7fb;
  background: rgba(255, 255, 255, 0.08);
}

.input {
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: rgba(7, 8, 17, 0.9);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #b8bbcc;
}
