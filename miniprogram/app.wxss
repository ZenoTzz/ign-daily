page {
  min-height: 100%;
  background: #0d0d0f;
  color: #f6f7fb;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background: #0d0d0f;
}

.panel {
  background: #171719;
  border: 1rpx solid #303136;
  border-radius: 20rpx;
  padding: 28rpx;
}

.muted {
  color: #9295a8;
}

.btn {
  height: 84rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 84rpx;
}

.btn-primary {
  color: #fff;
  background: #ed1c24;
}

.btn-ghost {
  color: #f6f7fb;
  background: #232327;
}

.input {
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #111113;
  color: #fff;
  border: 1rpx solid #303136;
}

.page-title { color:#fff; font-size:44rpx; line-height:1.2; font-weight:900; }
.page-subtitle { margin-top:10rpx; color:#8f9199; font-size:24rpx; line-height:1.5; }
.section-label { margin:28rpx 0 16rpx; color:#f4f4f5; font-size:30rpx; font-weight:800; }
.empty-state { padding:72rpx 28rpx; color:#8f9199; text-align:center; font-size:26rpx; line-height:1.65; }
.error-state { margin-bottom:20rpx; padding:22rpx; color:#ff9ea3; background:rgba(237,28,36,.09); border:1rpx solid rgba(237,28,36,.25); border-radius:16rpx; font-size:24rpx; }

.tag {
  display: inline-block;
  min-height: 40rpx;
  line-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #b8bbcc;
}
