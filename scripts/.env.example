# 环境变量配置示例
# 复制此文件为 .env 并填入真实值（.env 已在 .gitignore 中）

# GitHub Personal Access Token（用于 git_push.py 推送代码）
GITHUB_PAT_IGN_DAILY=ghp_your_token_here
GITHUB_USER_IGN_DAILY=ZenoTzz

# Optional: local OpenAI-compatible API translator.
# GitHub Actions should use repository Secrets/Variables instead:
#   Secret: TRANSLATOR_API_KEY, or provider-specific GEMINI_API_KEY / DEEPSEEK_API_KEY
#   Variable: TRANSLATOR_MODEL=deepseek-v4-flash
#   Variable: TRANSLATOR_BASE_URL=https://api.deepseek.com
TRANSLATOR_API_KEY=sk-your_api_key_here
# GEMINI_API_KEY=your_google_ai_studio_key_here
# GOOGLE_API_KEY=your_google_ai_studio_key_here
# DEEPSEEK_API_KEY=sk-your_deepseek_key_here
TRANSLATOR_MODEL=deepseek-v4-flash
TRANSLATOR_BASE_URL=https://api.deepseek.com

# Optional RSS fallback for mainland servers. Use a Worker/proxy outside
# mainland China when direct IGN/FeedBurner access is unstable.
# The proxy should return the upstream RSS XML unchanged.
# IGN_DAILY_RSS_PROXY_URL=https://your-worker.example.workers.dev/rss?url={url}
# IGN_DAILY_RSS_TIMEOUT=10
